// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Post {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  price        Int
  images       String[]
  address      String
  city         String
  bedroom      Int
  bathroom     Int
  latitude     String
  longitude    String
  type         Type
  property     Property
  createdAt    DateTime    @default(now())
  user         User        @relation(fields: [userId], references: [id])
  userId       String      @db.ObjectId
  postDetail   PostDetail?
  savedPosts   SavedPost[]
  
  // Enhanced property data
  neighborhood Json?       // Stores neighborhood information
  amenities    String[]    @default([]) // Building amenities
  features     String[]    @default([]) // Property features
  floorPlan    String?     // URL to floor plan image
  virtualTour  String?     // URL to virtual tour
  yearBuilt    Int?        // Year the property was built
  sqft         Int?        // Square footage
  status       ListingStatus @default(available)

  // Geospatial — GeoJSON Point for MongoDB 2dsphere index
  // { type: "Point", coordinates: [lng, lat] }
  // Index created at runtime by listing-service via $runCommandRaw
  location     Json?
}

enum Type {
  buy
  rent
}

enum ListingStatus {
  available
  under_offer
  sold
}

enum Property {
  apartment
  house
  condo
  land
  villa
}

enum UserRole {
  user
  agent
  admin
}

model PostDetail {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  desc       String
  utilities  String?
  pet        String?
  income     String?
  size       Int?
  school     Int?
  bus        Int?
  restaurant Int?
  post       Post    @relation(fields: [postId], references: [id])
  postId     String  @unique @db.ObjectId
}

model SavedPost {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])
  userId    String   @db.ObjectId
  postId    String   @db.ObjectId
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model User {
  id                    String      @id @default(auto()) @map("_id") @db.ObjectId
  email                 String      @unique
  username              String      @unique
  password              String?
  avatar                String?
  role                  UserRole    @default(user)
  isBanned              Boolean     @default(false)
  isEmailVerified       Boolean     @default(false)
  emailVerificationToken String?
  passwordResetToken    String?
  passwordResetExpiry   DateTime?
  oauthProvider         String?
  oauthId               String?
  createdAt             DateTime    @default(now())
  posts                 Post[]
  savedPosts            SavedPost[]
  chats                 Chat[]      @relation(fields: [chatIDs], references: [id])
  chatIDs               String[]    @db.ObjectId
}

model Chat {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  users     User[]    @relation(fields: [userIDs], references: [id])
  userIDs   String[]  @db.ObjectId
  createdAt DateTime  @default(now())
  updatedAt    DateTime  @updatedAt    
  seenBy    String[]  @db.ObjectId
  messages  Message[]
  lastMessage String?
}

model Booking {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  userId             String   @db.ObjectId
  postId             String   @db.ObjectId
  visitType          String
  date               String
  time               String
  fee                Int
  contactName        String
  contactEmail       String
  contactPhone       String
  notes              String?
  paymentId          String?
  paymentMethod      String   @default("demo")
  confirmationNumber String
  status             String   @default("confirmed")
  createdAt          DateTime @default(now())
}

model PriceHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    String   @db.ObjectId
  price     Int
  date      DateTime @default(now())
}

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  text      String?
  userId    String
  chat      Chat     @relation(fields: [chatId], references: [id])
  chatId    String   @db.ObjectId
  fileUrl   String?
  fileName  String?
  fileType  String?
  fileSize  Int?
  createdAt DateTime @default(now())
}

// CQRS / Event Sourcing — immutable append-only log of every domain event.
// Written by each service on every state change.
// Query via GET /api/admin/event-log for full audit trail and replay.
model EventLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String   // e.g. "listing.created", "listing.priceChanged", "booking.created"
  entityId  String   // the ID of the affected entity (postId, bookingId, etc.)
  data      String   // JSON-serialised event payload (immutable snapshot)
  userId    String?  // actor who triggered the event (null for system events)
  createdAt DateTime @default(now())

  @@index([type])
  @@index([entityId])
  @@index([createdAt])
}
