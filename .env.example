# Database Configuration
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/realestate"

# JWT Authentication
JWT_SECRET_KEY="your-super-secret-jwt-key-minimum-32-characters-long"

# Email Configuration (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM="Real Estate App <your-email@gmail.com>"

# CORS & Client Configuration
CLIENT_URL=http://localhost:5174
SOCKET_URL=http://localhost:4000

# Deployment URLs (Update these after deployment)
FRONTEND_URL=https://your-frontend.vercel.app
BACKEND_URL=https://your-api.vercel.app
SOCKET_SERVER_URL=https://your-socket.railway.app

# Environment
NODE_ENV=development
PORT=8800

# Optional: External Service APIs
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret